# MQTT Broker (Phase 3)
# Install: winget install mosquitto
# For Wokwi cloud hardware mode, use a broker reachable from the public internet.
MQTT_HOST=localhost
MQTT_PORT=1883
IOT_MODE=simulator

# Telegram Bot (Phase 5)
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Weather API (optional)
METEO_VILLE=Rabat
METEO_PAYS=MA
