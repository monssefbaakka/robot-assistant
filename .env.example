# Copy this file to `.env` to make the app load these values automatically.
#
# MQTT Broker (Phase 3)
# Install: winget install mosquitto
# For Wokwi / VS Code hardware mode, use a broker reachable from the ESP32 simulator.
# Python and Wokwi must use the same broker and the same IOT_MODE.
MQTT_HOST=localhost
MQTT_PORT=1883
IOT_MODE=simulator

# Cloud LLM (optional)
# Use Groq for online inference when the robot/server cannot run Ollama locally.
# Keep the real key only in `.env`, never in committed files.
LLM_PROVIDER=auto
GROQ_API_KEY=replace_with_your_groq_key
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MAX_TOKENS=350

# Telegram Bot (Phase 5)
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Weather API (optional)
METEO_VILLE=Rabat
METEO_PAYS=MA
